---
/**
 * LeadMagnetCTA — Combined Gumroad download + newsletter signup call-to-action.
 * Use this on the homepage or landing pages to drive both downloads and subscribers.
 */
import GumroadOverlay from "./GumroadOverlay.astro";

interface Props {
  productCode?: string;
}

const {
  productCode = "ai-tools-cheatsheet",
} = Astro.props;
---

<section class="relative overflow-hidden rounded-3xl">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-br from-brand-teal/10 via-surface-900 to-brand-amber/10"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-brand-teal/5 via-transparent to-transparent"></div>
  
  <div class="relative border border-surface-700/50 rounded-3xl p-8 md:p-16">
    <div class="max-w-3xl mx-auto text-center">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-teal/10 border border-brand-teal/20 text-brand-teal text-xs font-medium mb-6">
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path>
        </svg>
        FREE RESOURCE
      </div>

      <h2 class="font-display font-bold text-3xl md:text-5xl text-white mb-4 leading-tight">
        Marketing AI Cheat Sheet
      </h2>
      <p class="text-zinc-400 text-lg md:text-xl mb-8 leading-relaxed max-w-2xl mx-auto">
        50+ AI tools ranked and reviewed. Pricing, best use cases, and honest takes — 
        all in one printable reference guide.
      </p>

      <!-- Features -->
      <div class="flex flex-wrap justify-center gap-4 mb-10">
        <span class="flex items-center gap-1.5 text-sm text-zinc-300">
          <svg class="w-4 h-4 text-brand-teal" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
          50+ tools reviewed
        </span>
        <span class="flex items-center gap-1.5 text-sm text-zinc-300">
          <svg class="w-4 h-4 text-brand-teal" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
          11 categories
        </span>
        <span class="flex items-center gap-1.5 text-sm text-zinc-300">
          <svg class="w-4 h-4 text-brand-teal" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
          Updated for 2026
        </span>
        <span class="flex items-center gap-1.5 text-sm text-zinc-300">
          <svg class="w-4 h-4 text-brand-teal" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
          PDF download
        </span>
      </div>

      <!-- CTA Button -->
      <GumroadOverlay productCode={productCode} text="Download Free Cheat Sheet" />
      
      <p class="text-zinc-600 text-xs mt-4">
        Free download · No credit card required
      </p>
    </div>
  </div>
</section>
