---
interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<section class={`newsletter ${compact ? 'newsletter-compact' : 'newsletter-full'}`}>
  <div class={compact ? '' : 'container'}>
    <div class="newsletter-inner">
      {!compact && <span class="newsletter-badge">📬 Weekly Newsletter</span>}
      <h2 class="newsletter-title">
        {compact ? 'Stay in the loop' : 'Get the best AI tools in your inbox'}
      </h2>
      <p class="newsletter-desc">
        {compact
          ? 'Weekly curated AI tool picks. No spam.'
          : 'Every week we send a curated roundup of the best new AI tools, honest reviews, and tips for getting more out of AI. No hype, no fluff.'}
      </p>
      <div class="newsletter-embed">
        <iframe
          src="https://embeds.beehiiv.com/universal"
          data-test-id="beehiiv-embed"
          frameborder="0"
          scrolling="no"
          style="width:100%;max-width:480px;height:52px;border:none;background:transparent;"
        ></iframe>
        <noscript>
          <p class="newsletter-fallback">
            <a href="https://newsletter.example.com" target="_blank" rel="noopener" class="btn-primary">
              Subscribe to our newsletter →
            </a>
          </p>
        </noscript>
      </div>
      <p class="newsletter-privacy">Free forever. Unsubscribe anytime. No spam.</p>
    </div>
  </div>
</section>

<style>
  .newsletter-full {
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(168, 85, 247, 0.1));
    border: 1px solid rgba(99, 102, 241, 0.2);
    border-radius: 16px;
    padding: 3rem;
    text-align: center;
    margin: 2rem 0;
  }

  .newsletter-compact {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 2rem;
    text-align: center;
  }

  .newsletter-inner {
    max-width: 560px;
    margin: 0 auto;
  }

  .newsletter-badge {
    display: inline-block;
    background: rgba(99, 102, 241, 0.15);
    color: #818cf8;
    padding: 0.375rem 1rem;
    border-radius: 9999px;
    font-size: 0.8125rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .newsletter-title {
    font-size: 1.75rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
  }

  .newsletter-compact .newsletter-title {
    font-size: 1.25rem;
  }

  .newsletter-desc {
    color: var(--color-text-muted);
    font-size: 1rem;
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .newsletter-compact .newsletter-desc {
    font-size: 0.875rem;
    margin-bottom: 1rem;
  }

  .newsletter-embed {
    display: flex;
    justify-content: center;
    margin-bottom: 0.75rem;
  }

  .newsletter-privacy {
    color: var(--color-text-muted);
    font-size: 0.75rem;
  }

  .newsletter-fallback {
    text-align: center;
  }
</style>
