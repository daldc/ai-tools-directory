---
import Layout from "../../layouts/Layout.astro";
import CategoryCard from "../../components/CategoryCard.astro";
import Newsletter from "../../components/Newsletter.astro";
import { categories, getToolsByCategory } from "../../data/tools";

const categoryData = categories.map((cat) => ({
  ...cat,
  count: getToolsByCategory(cat.name).length,
}));
---

<Layout title="Categories" description="Browse AI tools by category. 11 categories covering assistants, coding, design, video, writing, productivity, and more.">

  <section class="max-w-7xl mx-auto px-6 pt-12 pb-6">
    <h1 class="font-display font-bold text-4xl md:text-5xl text-white mb-3">
      Categories
    </h1>
    <p class="text-zinc-400 text-lg mb-12">
      {categories.length} categories to help you find the right tool
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {categoryData.map((cat) => (
        <CategoryCard
          name={cat.name}
          slug={cat.slug}
          description={cat.description}
          icon={cat.icon}
          count={cat.count}
        />
      ))}
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-6 py-20">
    <Newsletter />
  </section>

</Layout>
