---
import Layout from "../../layouts/Layout.astro";
import ToolCard from "../../components/ToolCard.astro";
import Newsletter from "../../components/Newsletter.astro";
import { categories, getToolsByCategory } from "../../data/tools";

export function getStaticPaths() {
  return categories.map((cat) => ({
    params: { slug: cat.slug },
    props: { category: cat },
  }));
}

const { category } = Astro.props;
const categoryTools = getToolsByCategory(category.name).sort((a, b) => b.rating - a.rating);
---

<Layout title={category.name} description={`Browse the best ${category.name} AI tools. ${categoryTools.length} curated tools with ratings, pricing, and reviews.`}>

  <section class="max-w-7xl mx-auto px-6 pt-12 pb-6">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-zinc-600 mb-8">
      <a href="/" class="hover:text-brand-teal transition-colors">Home</a>
      <span>/</span>
      <a href="/categories" class="hover:text-brand-teal transition-colors">Categories</a>
      <span>/</span>
      <span class="text-zinc-400">{category.name}</span>
    </nav>

    <div class="flex items-center gap-4 mb-3">
      <span class="text-4xl">{category.icon}</span>
      <h1 class="font-display font-bold text-4xl md:text-5xl text-white">
        {category.name}
      </h1>
    </div>
    <p class="text-zinc-400 text-lg mb-12 max-w-2xl">
      {category.description}
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
      {categoryTools.map((tool) => (
        <ToolCard tool={tool} />
      ))}
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-6 py-20">
    <Newsletter />
  </section>

</Layout>
