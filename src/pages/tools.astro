---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';
import Newsletter from '../components/Newsletter.astro';
import { tools, categories, categoryNameToSlug } from '../utils/tools';
---

<BaseLayout title="All AI Tools — AI Tools Directory" description="Browse all 95+ curated AI tools with honest reviews, pricing, and feature breakdowns.">
  <section class="section">
    <div class="container">
      <h1 class="section-title">All Tools</h1>
      <p class="section-subtitle">Browse {tools.length} curated AI tools across {categories.length} categories</p>

      <!-- Search & Filters -->
      <div class="filters">
        <div class="search-wrapper">
          <span class="search-icon">🔍</span>
          <input
            type="text"
            class="search-input"
            id="search"
            placeholder="Search tools by name, category, or description..."
            autocomplete="off"
          />
        </div>
        <div class="filter-row">
          <div class="filter-group">
            <label class="filter-label">Category</label>
            <select id="filter-category" class="filter-select">
              <option value="">All Categories</option>
              {categories.map(cat => (
                <option value={cat.name}>{cat.icon} {cat.name}</option>
              ))}
            </select>
          </div>
          <div class="filter-group">
            <label class="filter-label">Pricing</label>
            <select id="filter-pricing" class="filter-select">
              <option value="">All Pricing</option>
              <option value="free">Free</option>
              <option value="freemium">Freemium</option>
              <option value="paid">Paid</option>
            </select>
          </div>
          <div class="filter-group">
            <label class="filter-label">Sort</label>
            <select id="filter-sort" class="filter-select">
              <option value="rating">Highest Rated</option>
              <option value="name">Name (A-Z)</option>
              <option value="category">Category</option>
            </select>
          </div>
        </div>
      </div>

      <p class="results-count" id="results-count">{tools.length} tools</p>

      <div class="tools-grid" id="tools-grid">
        {tools.sort((a, b) => b.rating - a.rating).map(tool => (
          <div class="tool-item"
            data-name={tool.name.toLowerCase()}
            data-category={tool.category}
            data-pricing={tool.pricingModel}
            data-description={tool.description.toLowerCase()}
            data-rating={tool.rating}
          >
            <ToolCard tool={tool} />
          </div>
        ))}
      </div>

      <div id="no-results" style="display:none;" class="no-results">
        <p>No tools found matching your filters. Try adjusting your search.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <Newsletter compact />
    </div>
  </section>
</BaseLayout>

<script>
  const search = document.getElementById('search') as HTMLInputElement;
  const categoryFilter = document.getElementById('filter-category') as HTMLSelectElement;
  const pricingFilter = document.getElementById('filter-pricing') as HTMLSelectElement;
  const sortFilter = document.getElementById('filter-sort') as HTMLSelectElement;
  const grid = document.getElementById('tools-grid')!;
  const counter = document.getElementById('results-count')!;
  const noResults = document.getElementById('no-results')!;

  function filterTools() {
    const query = search.value.toLowerCase().trim();
    const category = categoryFilter.value;
    const pricing = pricingFilter.value;
    const items = Array.from(grid.querySelectorAll('.tool-item')) as HTMLElement[];

    let visible = 0;

    items.forEach(item => {
      const name = item.dataset.name || '';
      const cat = item.dataset.category || '';
      const price = item.dataset.pricing || '';
      const desc = item.dataset.description || '';

      const matchSearch = !query || name.includes(query) || cat.toLowerCase().includes(query) || desc.includes(query);
      const matchCategory = !category || cat === category;
      const matchPricing = !pricing || price === pricing;

      if (matchSearch && matchCategory && matchPricing) {
        item.style.display = '';
        visible++;
      } else {
        item.style.display = 'none';
      }
    });

    counter.textContent = `${visible} tool${visible !== 1 ? 's' : ''}`;
    noResults.style.display = visible === 0 ? 'block' : 'none';

    // Sort
    const sortBy = sortFilter.value;
    const sorted = items.sort((a, b) => {
      if (sortBy === 'name') return (a.dataset.name || '').localeCompare(b.dataset.name || '');
      if (sortBy === 'category') return (a.dataset.category || '').localeCompare(b.dataset.category || '');
      return parseFloat(b.dataset.rating || '0') - parseFloat(a.dataset.rating || '0');
    });
    sorted.forEach(item => grid.appendChild(item));
  }

  search.addEventListener('input', filterTools);
  categoryFilter.addEventListener('change', filterTools);
  pricingFilter.addEventListener('change', filterTools);
  sortFilter.addEventListener('change', filterTools);
</script>

<style>
  .filters {
    margin-bottom: 1.5rem;
  }

  .search-wrapper {
    position: relative;
    margin-bottom: 1rem;
  }

  .search-icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1rem;
  }

  .filter-row {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .filter-group {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .filter-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .filter-select {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.5rem 1rem;
    color: var(--color-text);
    font-size: 0.875rem;
    font-family: inherit;
    cursor: pointer;
    outline: none;
  }

  .filter-select:focus {
    border-color: var(--color-accent);
  }

  .results-count {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
  }

  .no-results {
    text-align: center;
    padding: 3rem;
    color: var(--color-text-muted);
    font-size: 1.125rem;
  }
</style>
