---
import Layout from "../../layouts/Layout.astro";
import StarRating from "../../components/StarRating.astro";
import ToolCard from "../../components/ToolCard.astro";
import { tools, getToolBySlug, getRelatedTools } from "../../data/tools";

export function getStaticPaths() {
  return tools.map((tool) => ({
    params: { slug: tool.slug },
  }));
}

const { slug } = Astro.params;
const tool = getToolBySlug(slug!)!;
const relatedTools = getRelatedTools(tool, 4);

const pricingBadgeClass = {
  free: "badge-free",
  freemium: "badge-freemium",
  paid: "badge-paid",
}[tool.pricing];

const pricingLabel = {
  free: "Free",
  freemium: tool.priceStarting ? `Freemium — from ${tool.priceStarting}` : "Freemium",
  paid: tool.priceStarting ? `Paid — from ${tool.priceStarting}` : "Paid",
}[tool.pricing];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: tool.name,
  description: tool.description,
  url: tool.url,
  applicationCategory: "BusinessApplication",
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: tool.rating,
    bestRating: 5,
    worstRating: 1,
  },
  offers: {
    "@type": "Offer",
    price: tool.pricing === "free" ? "0" : undefined,
    priceCurrency: "USD",
  },
};
---

<Layout title={tool.name} description={tool.description}>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <section class="max-w-5xl mx-auto px-6 pt-12">
    <nav class="flex items-center gap-2 text-sm text-zinc-600 mb-8">
      <a href="/" class="hover:text-brand-teal transition-colors">Home</a>
      <span>/</span>
      <a href="/browse" class="hover:text-brand-teal transition-colors">Browse</a>
      <span>/</span>
      <span class="text-zinc-400">{tool.name}</span>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      <div class="lg:col-span-2">
        <div class="flex items-start gap-6 mb-8">
          <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-surface-800 to-surface-700 flex items-center justify-center border border-surface-700/50 shrink-0">
            <span class="font-display font-bold text-brand-teal text-3xl">
              {tool.name.charAt(0)}
            </span>
          </div>
          <div>
            <h1 class="font-display font-bold text-3xl md:text-4xl text-white mb-2">
              {tool.name}
            </h1>
            <div class="flex flex-wrap items-center gap-3">
              <StarRating rating={tool.rating} size="md" />
              <span class={`badge ${pricingBadgeClass}`}>{pricingLabel}</span>
            </div>
          </div>
        </div>

        <div class="mb-10">
          <p class="text-zinc-300 text-lg leading-relaxed">{tool.description}</p>
        </div>

        <div class="mb-10">
          <h2 class="font-display font-semibold text-xl text-white mb-4">Key Features</h2>
          <ul class="space-y-3">
            {tool.features.map((feature) => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-brand-teal shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-zinc-300">{feature}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
          <div class="card-glow p-6">
            <h3 class="font-display font-semibold text-white mb-4 flex items-center gap-2">
              <span class="w-6 h-6 rounded-full bg-emerald-500/15 flex items-center justify-center">
                <svg class="w-3.5 h-3.5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </span>
              Pros
            </h3>
            <ul class="space-y-2">
              {tool.pros.map((pro) => (
                <li class="text-zinc-400 text-sm flex items-start gap-2">
                  <span class="text-emerald-400 mt-1">+</span>
                  {pro}
                </li>
              ))}
            </ul>
          </div>
          <div class="card-glow p-6">
            <h3 class="font-display font-semibold text-white mb-4 flex items-center gap-2">
              <span class="w-6 h-6 rounded-full bg-brand-coral/15 flex items-center justify-center">
                <svg class="w-3.5 h-3.5 text-brand-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </span>
              Cons
            </h3>
            <ul class="space-y-2">
              {tool.cons.map((con) => (
                <li class="text-zinc-400 text-sm flex items-start gap-2">
                  <span class="text-brand-coral mt-1">&minus;</span>
                  {con}
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div class="flex flex-wrap gap-2 mb-10">
          {tool.tags.map((tag) => (
            <span class="text-xs px-3 py-1 rounded-full bg-surface-800 text-zinc-500 border border-surface-700/30">
              {tag}
            </span>
          ))}
        </div>

        <div class="flex gap-4">
          <a href={tool.url} target="_blank" rel="noopener noreferrer" class="btn-primary">
            Visit {tool.name} →
          </a>
          <a href="/browse" class="btn-secondary">
            ← Back to Directory
          </a>
        </div>
      </div>

      <aside class="lg:col-span-1">
        <div class="sticky top-24 space-y-6">
          <div class="card-glow p-6">
            <h3 class="font-display font-semibold text-white text-sm mb-4">Quick Info</h3>
            <dl class="space-y-3 text-sm">
              <div class="flex justify-between">
                <dt class="text-zinc-500">Category</dt>
                <dd class="text-zinc-300">{tool.category}</dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-zinc-500">Pricing</dt>
                <dd class="text-zinc-300 capitalize">{tool.pricing}</dd>
              </div>
              {tool.priceStarting && (
                <div class="flex justify-between">
                  <dt class="text-zinc-500">Starting at</dt>
                  <dd class="text-zinc-300">{tool.priceStarting}</dd>
                </div>
              )}
              <div class="flex justify-between">
                <dt class="text-zinc-500">Rating</dt>
                <dd class="text-zinc-300">{tool.rating}/5</dd>
              </div>
            </dl>
          </div>

          {relatedTools.length > 0 && (
            <div>
              <h3 class="font-display font-semibold text-white text-sm mb-4">Related Tools</h3>
              <div class="space-y-3">
                {relatedTools.map((related) => (
                  <a href={`/tools/${related.slug}`} class="card-glow block p-4 group">
                    <div class="flex items-center gap-3">
                      <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-surface-800 to-surface-700 flex items-center justify-center border border-surface-700/50">
                        <span class="font-display font-bold text-brand-teal text-sm">
                          {related.name.charAt(0)}
                        </span>
                      </div>
                      <div>
                        <div class="font-display font-medium text-sm text-white group-hover:text-brand-teal transition-colors">
                          {related.name}
                        </div>
                        <div class="text-xs text-zinc-600">{related.category}</div>
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      </aside>
    </div>
  </section>

</Layout>
