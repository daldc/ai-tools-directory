# =============================================================================
# Beehiiv Newsletter Integration - "The AI Marketing Stack"
# =============================================================================
# Required for the /api/subscribe endpoint.
# Get these from: beehiiv.com → Settings → API
#
# BEEHIIV_API_KEY: Your Beehiiv API key (starts with "bh_")
# BEEHIIV_PUBLICATION_ID: Publication ID for "The AI Marketing Stack" 
#
BEEHIIV_API_KEY=your_api_key_here
BEEHIIV_PUBLICATION_ID=pub_2b74f984-deaa-4e23-899c-cab1936fb1e7

# =============================================================================
# Gumroad Store Integration - dallasc.gumroad.com
# =============================================================================
# Store configuration for The AI Marketing Stack products
# Get these from: gumroad.com → Dashboard → Product settings
#
GUMROAD_USERNAME=dallasc
GUMROAD_STORE_URL=https://dallasc.gumroad.com
GUMROAD_PRODUCT_CHEATSHEET=ai-tools-cheatsheet
GUMROAD_PRODUCT_UTM_BUILDER=utm-builder

# =============================================================================
# Analytics & Tracking
# =============================================================================
# UTM parameter defaults for integrated campaigns
#
UTM_SOURCE_DEFAULT=ai_marketing_stack
UTM_MEDIUM_DEFAULT=website
UTM_CAMPAIGN_DEFAULT=integrated_signup
